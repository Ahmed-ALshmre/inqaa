# Dashboard authentication
API_SECRET_KEY=change-me-local-api-secret
DASHBOARD_PASSWORD=admin123
PUBLIC_URL=https://your-railway-domain.up.railway.app

# OpenRouter / AI models
OPENROUTER_API_KEY=
MAIN_MODEL=google/gemini-3-flash-preview
IMPROVE_MODEL=google/gemini-3-flash-preview
CHECKER_MODEL=google/gemini-3.1-pro-preview
VISION_MODEL=google/gemini-3.1-pro-preview
CATALOG_MATCH_MODEL=google/gemini-2.5-flash
CATALOG_MATCH_ENABLED=1
CHECKER_ENABLED=0
VISION_ENABLED=1

# ManyChat
# Use MANYCHAT_API_KEY normally. MANYCHAT_KEY and MC_API_KEY are fallback aliases.
MANYCHAT_API_KEY=
MANYCHAT_KEY=
MC_API_KEY=
MANYCHAT_MESSAGE_TAG=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ORDER_TELEGRAM_CHAT_ID=-1003959669538

# App behavior
HUMAN_REPLY_WEBHOOK_URL=
HUMAN_REVIEW_ALL_IMAGES=1
DISABLE_CLIP=1
ASYNC_WEBHOOK=1
DEBOUNCE_DELAY=35
CATALOG_IMAGE_PATH=Gemini_Generated_Image_efqo6zefqo6zefqo.png
INCOMING_REQUESTS_FILE=incoming_requests.jsonl
